# ══════════════════════════════════════════════════════════
#  AURORA.AI — Environment Configuration
# ══════════════════════════════════════════════════════════

# ─── SAMBANOVA API (Primary LLM) ────────────────────────
# Get your key at: https://cloud.sambanova.ai/
# Just swap the key below whenever you need to change it
SAMBANOVA_API_KEY=4a11120c-f0fd-4a26-b6a9-e6617528294c
SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1
SAMBANOVA_MODEL=DeepSeek-V3.1-Terminus

# ─── Available SambaNova Models (change SAMBANOVA_MODEL above) ───
# DeepSeek-V3.1-Terminus         ← Default, good all-rounder
# Meta-Llama-3.3-70B-Instruct    ← Strong reasoning
# Meta-Llama-3.1-405B-Instruct   ← Largest, most capable
# Qwen2.5-72B-Instruct           ← Good for structured output
# Check https://cloud.sambanova.ai/ for latest models

# ─── LOCAL OLLAMA (Fallback LLM) ────────────────────────
# Only used when SambaNova fails or when LLM_STRATEGY=local_first
# Leave LOCAL_LLM_API_KEY empty if Ollama runs locally without auth
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3
LOCAL_LLM_API_KEY=

# ─── LLM STRATEGY ───────────────────────────────────────
# sambanova_first  → Try SambaNova, fall back to Ollama (RECOMMENDED)
# local_first      → Try Ollama, fall back to SambaNova
# sambanova_only   → Only SambaNova, no fallback
# local_only       → Only Ollama, no fallback
LLM_STRATEGY=sambanova_first

# ─── PAPER FINDER (Optional) ────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=UucfgQQ2pe6k1gwTxf1iT6MS2UUetyQx6UdsRVVl
UNPAYWALL_EMAIL=
PDF_DOWNLOAD_DIR=./downloaded_pdfs